{
    "name": "biger",
    "version": "0.1.0",
    "private": "true",
    "license": "MIT",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "prepare": "yarn build:common && yarn build:language-server && yarn build:webview && yarn build:extension",
        "build:common": "yarn --cwd packages/common run prepare",
        "build:extension": "yarn --cwd packages/extension run prepare",
        "build:language-server": "yarn --cwd packages/language-server run prepare",
        "build:webview": "yarn --cwd packages/webview run prepare",
        "test": "yarn --cwd packages/language-server run test && yarn --cwd packages/extension run test"
    },
    "dependencies": {
        "react": "^19.1.0",
        "react-dom": "^19.1.0"
    }
}
