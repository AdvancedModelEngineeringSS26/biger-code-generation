{
    "name": "biger",
    "displayName": "bigER",
    "description": "ER modeling tool for VS Code",
    "version": "0.1.0",
    "license": "MIT",
    "files": [
        "server",
        "syntaxes",
        "webview"
    ],
    "scripts": {
        "prepare": "yarn run clean && yarn run build",
        "clean": "rimraf pack",
        "build": "node esbuild.mjs",
        "watch": "node esbuild.mjs --watch",
        "export:cli": "node ./pack/extension/src/export-cli.cjs",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@biger/common": "*",
        "commander": "^10.0.1"
    },
    "devDependencies": {
        "@types/node": "^18.0.0",
        "@types/vscode": "~1.67.0",
        "esbuild": "^0.25.0",
        "rimraf": "^5.0.0",
        "sprotty-vscode": "^1.0.0",
        "vitest": "^2.1.0",
        "vscode-languageclient": "^9.0.1"
    },
    "engines": {
        "vscode": "^1.67.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [
            {
                "id": "entity-relationship",
                "aliases": [
                    "Entity Relationship",
                    "entity-relationship",
                    "ER"
                ],
                "extensions": [".er", ".erd"],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./media/file-icon-light.png",
                    "dark": "./media/file-icon-dark.png"
				}
            }
        ],
        "grammars": [
            {
                "language": "entity-relationship",
                "scopeName": "source.entity-relationship",
                "path": "syntaxes/entity-relationship.tmLanguage.json"
            }
        ],
        "commands": [
            {
                "command": "biger.diagram.open",
                "title": "Open in Diagram",
                "icon": "$(symbol-structure)",
                "category": "ER Diagram"
            },
            {
                "command": "biger.diagram.fit",
                "title": "Fit to Screen",
                "category": "ER Diagram"
            },
            {
                "command": "biger.diagram.center",
                "title": "Center selection",
                "category": "ER Diagram"
            },
            {
                "command": "biger.diagram.delete",
                "title": "Delete selected element",
                "category": "ER Diagram"
            },
            {
                "command": "biger.diagram.export",
                "title": "Export diagram to SVG",
                "category": "ER Diagram"
            },
            {
                "command": "biger.generate.sql.generic",
                "title": "Generate SQL",
                "category": "bigER"
            },
            {
                "command": "biger.generate.postgres",
                "title": "Generate PostgreSQL",
                "category": "bigER"
            },
            {
                "command": "biger.generate.mysql",
                "title": "Generate MySQL",
                "category": "bigER"
            },
            {
                "command": "biger.generate.mongo",
                "title": "Generate MongoDB",
                "category": "bigER"
            }
        ],
        "submenus": [
            {
                "id": "biger.generate",
                "label": "Generate"
            }
        ],
        "configuration": {
            "title": "bigER",
            "properties": {
                "biger.generateDrop": {
                    "type": "boolean",
                    "default": false,
                    "description": "Generate a file with DROP TABLE statements when generating SQL."
                }
            }
        },
        "menus": {
            "commandPalette": [
                {
                    "command": "biger.diagram.open",
                    "when": "editorLangId == 'entity-relationship'"
                },
                {
                    "command": "biger.diagram.fit",
                    "when": "er-diagram-focused"
                },
                {
                    "command": "biger.diagram.center",
                    "when": "er-diagram-focused"
                },
                {
                    "command": "biger.diagram.export",
                    "when": "er-diagram-focused"
                },
                {
                    "command": "biger.diagram.delete",
                    "when": "er-diagram-focused"
                },
                {
                    "command": "biger.generate.sql.generic",
                    "when": "editorLangId == 'entity-relationship'"
                },
                {
                    "command": "biger.generate.postgres",
                    "when": "editorLangId == 'entity-relationship'"
                },
                {
                    "command": "biger.generate.mysql",
                    "when": "editorLangId == 'entity-relationship'"
                },
                {
                    "command": "biger.generate.mongo",
                    "when": "editorLangId == 'entity-relationship'"
                }
            ],
            "editor/context": [
                {
                    "command": "biger.diagram.open",
                    "when": "editorLangId == 'entity-relationship'",
                    "group": "navigation"
                },
                {
                    "submenu": "biger.generate",
                    "when": "editorLangId == 'entity-relationship'",
                    "group": "2_workspace"
                }
            ],
            "editor/title": [
                {
                    "command": "biger.diagram.open",
                    "when": "editorLangId == 'entity-relationship'",
                    "group": "navigation"
                }
            ],
            "biger.generate": [
                {
                    "command": "biger.generate.sql.generic",
                    "group": "1_generate@1"
                },
                {
                    "command": "biger.generate.postgres",
                    "group": "1_generate@2"
                },
                {
                    "command": "biger.generate.mysql",
                    "group": "1_generate@3"
                },
                {
                    "command": "biger.generate.mongo",
                    "group": "1_generate@4"
                }
            ],
            "explorer/context": [
                {
                    "command": "biger.diagram.open",
                    "when": "resourceExtname == '.er' || resourceExtname == '.erd'",
                    "group": "navigation"
                },
                {
                    "submenu": "biger.generate",
                    "when": "resourceExtname == '.er' || resourceExtname == '.erd'",
                    "group": "2_workspace"
                }
            ]
        },
        "keybindings": [
            {
                "key": "ctrl+f",
                "mac": "cmd+f",
                "command": "biger.diagram.fit",
                "when": "er-diagram-focused"
            },
            {
                "key": "ctrl+c",
                "mac": "cmd+c",
                "command": "biger.diagram.center",
                "when": "er-diagram-focused"
            },
            {
                "key": "ctrl+backspace",
                "mac": "cmd+backspace",
                "command": "biger.diagram.delete",
                "when": "er-diagram-focused"
            }
        ]
    },
    "activationEvents": [
        "onLanguage:entity-relationship"
    ],
    "main": "./pack/extension/src/main.cjs"
}
