{
    "name": "biger-language-server",
    "description": "Language server of bigER",
    "version": "0.1.0",
    "private": true,
    "license": "MIT",
    "author": "Philipp-Lorenz Glaser",
    "type": "module",
    "dependencies": {
        "@biger/common": "*",
        "langium": "^4.2.0",
        "langium-sprotty": "^4.2.0",
        "reflect-metadata": "^0.2.2",
        "sprotty": "^1.4.0",
        "sprotty-elk": "^1.4.0",
        "vscode-languageserver": "^9.0.1"
    },
    "devDependencies": {
        "@electric-sql/pglite": "^0.2.0",
        "@testcontainers/mysql": "^10.16.0",
        "@types/node": "^18.0.0",
        "dt-sql-parser": "^4.0.0",
        "fast-check": "^3.23.0",
        "langium-cli": "^4.2.0",
        "libpg-query": "^17.0.0",
        "mongodb": "^7.4.0",
        "mysql2": "^3.11.0",
        "rimraf": "^5.0.0",
        "testcontainers": "^10.16.0",
        "typescript": "^5.7.3",
        "vitest": "^2.1.0"
    },
    "scripts": {
        "prepare": "yarn run clean && yarn run langium:generate && yarn run build",
        "clean": "rimraf src/generated",
        "build": "tsc --noEmit",
        "watch": "tsc --noEmit --watch",
        "langium:generate": "langium generate",
        "langium:watch": "langium generate --watch",
        "test": "vitest run",
        "test:watch": "vitest"
    }
}
